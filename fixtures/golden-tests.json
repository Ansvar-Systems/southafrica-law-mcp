{
  "$schema": "./golden-tests.schema.json",
  "version": "1.0",
  "mcp_name": "South Africa Law MCP",
  "description": "Golden contract tests for the South Africa Law MCP — 12 tests covering article retrieval, search, citation, cross-reference, and negative cases",
  "tests": [
    {
      "id": "za-001",
      "category": "article_retrieval",
      "description": "Retrieve POPIA Section 2 — purpose of the Act, covering the right to privacy and personal information protection",
      "tool": "get_provision",
      "input": {
        "law_identifier": "Protection of Personal Information Act 4 of 2013",
        "article": "2"
      },
      "assertions": {
        "result_not_empty": true,
        "text_contains": ["personal information", "right to privacy"],
        "fields_present": ["text", "article_number"],
        "text_not_empty": true
      }
    },
    {
      "id": "za-002",
      "category": "article_retrieval",
      "description": "Retrieve Cybercrimes Act Section 2 — unlawful access to computer systems",
      "tool": "get_provision",
      "input": {
        "law_identifier": "Cybercrimes Act 19 of 2020",
        "article": "2"
      },
      "assertions": {
        "result_not_empty": true,
        "text_contains": ["computer system", "access"],
        "fields_present": ["text", "article_number"],
        "text_not_empty": true
      }
    },
    {
      "id": "za-003",
      "category": "article_retrieval",
      "description": "Retrieve Companies Act Section 1 — interpretation and definitions",
      "tool": "get_provision",
      "input": {
        "law_identifier": "Companies Act 71 of 2008",
        "article": "1"
      },
      "assertions": {
        "result_not_empty": true,
        "any_result_contains": ["Companies Act", "interpretation", "definition"],
        "fields_present": ["text"],
        "text_not_empty": true
      }
    },
    {
      "id": "za-004",
      "category": "search",
      "description": "Full-text search for 'personal information' returns POPIA provisions",
      "tool": "search_legislation",
      "input": {
        "query": "personal information"
      },
      "assertions": {
        "result_not_empty": true,
        "min_results": 1,
        "any_result_contains": ["Protection of Personal Information", "POPIA", "personal information"]
      }
    },
    {
      "id": "za-005",
      "category": "search",
      "description": "Full-text search for 'cybercrime' returns Cybercrimes Act provisions",
      "tool": "search_legislation",
      "input": {
        "query": "cybercrime"
      },
      "assertions": {
        "result_not_empty": true,
        "min_results": 1,
        "any_result_contains": ["Cybercrimes Act", "cybercrime", "offence", "computer"]
      }
    },
    {
      "id": "za-006",
      "category": "search",
      "description": "Full-text search for 'electronic communication' returns ECTA provisions",
      "tool": "search_legislation",
      "input": {
        "query": "electronic communication"
      },
      "assertions": {
        "result_not_empty": true,
        "min_results": 1,
        "any_result_contains": ["Electronic Communications and Transactions", "ECTA", "electronic"]
      }
    },
    {
      "id": "za-007",
      "category": "citation_roundtrip",
      "description": "Citation for POPIA Section 2 includes SAFLII or gov.za URL pattern",
      "tool": "get_provision",
      "input": {
        "law_identifier": "Protection of Personal Information Act 4 of 2013",
        "article": "2"
      },
      "assertions": {
        "result_not_empty": true,
        "citation_url_pattern": "saflii\\.org|gov\\.za",
        "text_not_empty": true
      }
    },
    {
      "id": "za-008",
      "category": "citation_roundtrip",
      "description": "Citation for Cybercrimes Act Section 2 includes official identifier",
      "tool": "get_provision",
      "input": {
        "law_identifier": "Cybercrimes Act 19 of 2020",
        "article": "2"
      },
      "assertions": {
        "result_not_empty": true,
        "fields_present": ["text"],
        "text_not_empty": true
      }
    },
    {
      "id": "za-009",
      "category": "eu_cross_reference",
      "description": "POPIA relationship to EU GDPR — POPIA was significantly influenced by GDPR and EU data protection principles",
      "tool": "get_provision_eu_basis",
      "input": {
        "law_identifier": "Protection of Personal Information Act 4 of 2013"
      },
      "assertions": {
        "result_not_empty": true,
        "any_result_contains": ["GDPR", "General Data Protection Regulation", "2016/679", "data protection"]
      }
    },
    {
      "id": "za-010",
      "category": "eu_cross_reference",
      "description": "Cybercrimes Act relationship to the Budapest Convention on Cybercrime",
      "tool": "get_provision_eu_basis",
      "input": {
        "law_identifier": "Cybercrimes Act 19 of 2020"
      },
      "assertions": {
        "result_not_empty": true,
        "any_result_contains": ["Budapest Convention", "Convention on Cybercrime", "Council of Europe", "cybercrime"]
      }
    },
    {
      "id": "za-011",
      "category": "negative_test",
      "description": "Non-existent South African Act returns graceful error or empty result",
      "tool": "get_provision",
      "input": {
        "law_identifier": "Fictional Protea Conservation Act 2099",
        "article": "1"
      },
      "assertions": {
        "handles_gracefully": true
      }
    },
    {
      "id": "za-012",
      "category": "negative_test",
      "description": "Malformed section number returns graceful error or empty result",
      "tool": "get_provision",
      "input": {
        "law_identifier": "Protection of Personal Information Act 4 of 2013",
        "article": "999ZZZ-INVALID"
      },
      "assertions": {
        "handles_gracefully": true
      }
    }
  ]
}
