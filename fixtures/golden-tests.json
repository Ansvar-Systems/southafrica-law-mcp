{
  "$schema": "./golden-tests.schema.json",
  "version": "1.0",
  "mcp_name": "South Africa Law MCP",
  "description": "Golden contract tests for the South Africa Law MCP — 12 tests covering provision retrieval, search, citation, cross-reference, and negative cases",
  "tests": [
    {
      "id": "za-001",
      "category": "article_retrieval",
      "description": "Retrieve Accreditation Act Section 2 — purpose of the Act, establishing SANAS as accreditation body",
      "tool": "get_provision",
      "input": {
        "document_id": "accreditation-for-conformity-assessment-calibration-and-good",
        "section": "2"
      },
      "assertions": {
        "result_not_empty": true,
        "text_contains": ["accreditation", "SANAS"],
        "fields_present": ["results"],
        "text_not_empty": true
      }
    },
    {
      "id": "za-002",
      "category": "article_retrieval",
      "description": "Retrieve Accreditation Act Section 1 — definitions including accreditation body, calibration, GLP",
      "tool": "get_provision",
      "input": {
        "document_id": "accreditation-for-conformity-assessment-calibration-and-good",
        "section": "1"
      },
      "assertions": {
        "result_not_empty": true,
        "text_contains": ["accreditation body", "calibration"],
        "fields_present": ["results"],
        "text_not_empty": true
      }
    },
    {
      "id": "za-003",
      "category": "article_retrieval",
      "description": "Retrieve Close Corporations Act Section 1 — definitions including accounting records",
      "tool": "get_provision",
      "input": {
        "document_id": "close-corporations-act-1984",
        "section": "1"
      },
      "assertions": {
        "result_not_empty": true,
        "any_result_contains": ["Close Corporations", "accounting records", "corporation"],
        "fields_present": ["results"],
        "text_not_empty": true
      }
    },
    {
      "id": "za-004",
      "category": "search",
      "description": "Full-text search for 'accreditation' returns Accreditation Act provisions",
      "tool": "search_legislation",
      "input": {
        "query": "accreditation"
      },
      "assertions": {
        "result_not_empty": true,
        "min_results": 1,
        "any_result_contains": ["accreditation"]
      }
    },
    {
      "id": "za-005",
      "category": "search",
      "description": "Full-text search for 'definitions' returns provisions from multiple acts",
      "tool": "search_legislation",
      "input": {
        "query": "definitions"
      },
      "assertions": {
        "result_not_empty": true,
        "min_results": 1,
        "any_result_contains": ["definitions"]
      }
    },
    {
      "id": "za-006",
      "category": "search",
      "description": "Full-text search for 'broadcasting' returns Broadcasting Act provisions",
      "tool": "search_legislation",
      "input": {
        "query": "broadcasting"
      },
      "assertions": {
        "result_not_empty": true,
        "min_results": 1,
        "any_result_contains": ["Broadcasting"]
      }
    },
    {
      "id": "za-007",
      "category": "article_retrieval",
      "description": "Retrieve Accreditation Act Section 26 — regulations covering scope of SANAS accreditation",
      "tool": "get_provision",
      "input": {
        "document_id": "accreditation-for-conformity-assessment-calibration-and-good",
        "section": "26"
      },
      "assertions": {
        "result_not_empty": true,
        "text_contains": ["regulations", "SANAS"],
        "text_not_empty": true
      }
    },
    {
      "id": "za-008",
      "category": "article_retrieval",
      "description": "Retrieve Accreditation Act Section 27 — offences relating to false accreditation claims",
      "tool": "get_provision",
      "input": {
        "document_id": "accreditation-for-conformity-assessment-calibration-and-good",
        "section": "27"
      },
      "assertions": {
        "result_not_empty": true,
        "text_contains": ["offences"],
        "text_not_empty": true
      }
    },
    {
      "id": "za-009",
      "category": "eu_cross_reference",
      "description": "EU basis for Accreditation Act — returns empty references (no EU cross-references in free-tier DB)",
      "tool": "get_provision_eu_basis",
      "input": {
        "document_id": "accreditation-for-conformity-assessment-calibration-and-good"
      },
      "assertions": {
        "result_not_empty": true,
        "fields_present": ["results"]
      }
    },
    {
      "id": "za-010",
      "category": "list_sources",
      "description": "List all data sources backing this MCP server",
      "tool": "list_sources",
      "input": {},
      "assertions": {
        "result_not_empty": true,
        "text_not_empty": true
      }
    },
    {
      "id": "za-011",
      "category": "negative_test",
      "description": "Non-existent South African Act returns graceful error or empty result",
      "tool": "get_provision",
      "input": {
        "document_id": "fictional-protea-conservation-act-2099",
        "section": "1"
      },
      "assertions": {
        "handles_gracefully": true
      }
    },
    {
      "id": "za-012",
      "category": "negative_test",
      "description": "Malformed section number returns graceful error or empty result",
      "tool": "get_provision",
      "input": {
        "document_id": "accreditation-for-conformity-assessment-calibration-and-good",
        "section": "999ZZZ-INVALID"
      },
      "assertions": {
        "handles_gracefully": true
      }
    }
  ]
}
