{
  "name": "@ansvar/southafrica-law-mcp",
  "mcpName": "eu.ansvar/southafrica-law-mcp",
  "version": "1.0.0",
  "description": "South African law database covering POPIA, cybercrimes, electronic transactions, companies, and consumer protection law with full-text search via MCP",
  "type": "module",
  "main": "dist/server.js",
  "bin": {
    "southafrica-law-mcp": "dist/server.js"
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:contract": "vitest run __tests__/contract/",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "start": "node dist/server.js",
    "start:stdio": "node dist/server.js --stdio",
    "health": "curl -s http://localhost:3000/health | jq .",
    "build:db": "tsx scripts/build-db.ts",
    "build:db:free": "tsx scripts/build-db-free.ts",
    "ingest": "tsx scripts/ingest.ts",
    "drift:detect": "tsx scripts/drift-detect.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "node-sqlite3-wasm": "^0.8.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "eslint": "^9.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=18"
  },
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/Ansvar-Systems/southafrica-law-mcp"
  },
  "keywords": [
    "mcp",
    "south-africa",
    "law",
    "POPIA",
    "cybercrimes",
    "data-protection",
    "ECTA",
    "consumer-protection",
    "legal",
    "compliance",
    "Information Regulator"
  ],
  "author": "Ansvar Systems <engineering@ansvar.eu>",
  "homepage": "https://ansvar.eu",
  "bugs": {
    "url": "https://github.com/Ansvar-Systems/southafrica-law-mcp/issues"
  },
  "files": [
    "dist/",
    "data/",
    "fixtures/",
    "sources.yml",
    "server.json",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ]
}
