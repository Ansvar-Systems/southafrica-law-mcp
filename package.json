{
  "name": "@ansvar/southafrica-law-mcp",
  "mcpName": "eu.ansvar/southafrica-law-mcp",
  "version": "1.1.0",
  "description": "South African law database covering POPIA, cybercrimes, electronic transactions, companies, and consumer protection law with full-text search via MCP",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "southafrica-law-mcp": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "build:db": "tsx scripts/build-db.ts",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:contract": "vitest run __tests__/contract/",
    "ingest": "tsx scripts/ingest.ts",
    "check-updates": "tsx scripts/check-updates.ts",
    "drift:detect": "tsx scripts/drift-detect.ts",
    "validate": "vitest run && vitest run __tests__/contract/",
    "prepublishOnly": "npm run build",
    "postinstall": "node -e \"\" 2>/dev/null || true"
  },
  "dependencies": {
    "@ansvar/mcp-sqlite": "^1.0.3",
    "@modelcontextprotocol/sdk": "^1.25.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.15.29",
    "@vercel/node": "^5.6.4",
    "@vitest/coverage-v8": "^4.0.18",
    "better-sqlite3": "^12.6.2",
    "cheerio": "^1.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=18"
  },
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/Ansvar-Systems/southafrica-law-mcp"
  },
  "keywords": [
    "mcp",
    "south-africa",
    "law",
    "POPIA",
    "cybercrimes",
    "data-protection",
    "ECTA",
    "consumer-protection",
    "legal",
    "compliance",
    "Information Regulator"
  ],
  "author": "Ansvar Systems <engineering@ansvar.eu>",
  "homepage": "https://ansvar.eu",
  "bugs": {
    "url": "https://github.com/Ansvar-Systems/southafrica-law-mcp/issues"
  },
  "files": [
    "dist",
    "data/database.db"
  ]
}
